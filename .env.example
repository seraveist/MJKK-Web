# ========================================
# 마자까까 내전 집계 — 환경변수 설정
# ========================================
# 이 파일을 .env로 복사 후 실제 값을 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
#
# Cloud Run 배포 시: GCP Secret Manager를 사용하여 환경변수 주입 권장
# https://cloud.google.com/run/docs/configuring/secrets

# ---- MongoDB ----
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_CLUSTER=cluster0.6nqoq8u.mongodb.net
DB_NAME=totalLogDB
COLLECTION_NAME=gameLog

# ---- 작혼(Majsoul) API 인증 ----
MS_USERNAME=your_majsoul_email
MS_PASSWORD=your_majsoul_password
MS_HOST=https://game.maj-soul.com

# ---- Flask ----
SECRET_KEY=your_random_secret_key_here
FLASK_ENV=production

# ---- 시즌 설정 ----
SEASON_BASE_YEAR=2023

# ---- 패보 업로드 보안 ----
# 비어있으면 비밀번호 검증 안 함 (개발용)
# 운영 시 반드시 설정하세요
UPLOAD_PASSWORD=your_upload_password_here
